{
  "id": "00000000-0000-0000-0000-000000000099",
  "name": "Block Trackers & Ads",
  "description": "Blocks common ad networks, analytics trackers, and tracking pixels across all sites",
  "site": "*",
  "enabled": true,
  "priority": 100,
  "rules": [
    { "type": "block", "match": { "urlPattern": "*google-analytics.com*" } },
    { "type": "block", "match": { "urlPattern": "*googletagmanager.com*" } },
    { "type": "block", "match": { "urlPattern": "*googlesyndication.com*" } },
    { "type": "block", "match": { "urlPattern": "*googleadservices.com*" } },
    { "type": "block", "match": { "urlPattern": "*doubleclick.net*" } },
    { "type": "block", "match": { "urlPattern": "*facebook.com/tr*" } },
    { "type": "block", "match": { "urlPattern": "*connect.facebook.net*" } },
    { "type": "block", "match": { "urlPattern": "*adnxs.com*" } },
    { "type": "block", "match": { "urlPattern": "*amazon-adsystem.com*" } },
    { "type": "block", "match": { "urlPattern": "*taboola.com*" } },
    { "type": "block", "match": { "urlPattern": "*outbrain.com*" } },
    { "type": "block", "match": { "urlPattern": "*criteo.com*" } },
    { "type": "block", "match": { "urlPattern": "*hotjar.com*" } },
    { "type": "block", "match": { "urlPattern": "*mixpanel.com*" } },
    { "type": "block", "match": { "urlPattern": "*segment.io*" } },
    { "type": "block", "match": { "urlPattern": "*pubmatic.com*" } },
    { "type": "block", "match": { "urlPattern": "*rubiconproject.com*" } },
    { "type": "block", "match": { "urlPattern": "*openx.net*" } },
    { "type": "block", "match": { "urlPattern": "*popads.net*" } },
    { "type": "block", "match": { "urlPattern": "*propellerads.com*" } }
  ]
}
