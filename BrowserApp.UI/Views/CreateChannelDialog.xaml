<ui:FluentWindow x:Class="BrowserApp.UI.Views.CreateChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Create Channel"
        Height="340" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        Style="{StaticResource ModernDialogWindowStyle}">

    <Grid Margin="20" Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Create Channel" ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>

        <TextBlock Grid.Row="1" Text="Create a new channel to share rules with others."
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <ui:TextBox Grid.Row="2" x:Name="ChannelNameInput"
                    PlaceholderText="Channel name"
                    Margin="0,0,0,10"/>

        <ui:TextBox Grid.Row="3" x:Name="ChannelDescriptionInput"
                    PlaceholderText="Description (optional)"
                    Margin="0,0,0,10"/>

        <ui:PasswordBox Grid.Row="4" x:Name="ChannelPasswordInput"
                        PlaceholderText="Password (min 4 characters)"
                        Margin="0,0,0,4"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <ui:Button Content="Cancel"
                       IsCancel="True"
                       Click="CancelButton_Click"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Create"
                       Appearance="Primary"
                       IsDefault="True"
                       Click="CreateButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
