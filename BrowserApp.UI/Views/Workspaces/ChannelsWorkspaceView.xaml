<UserControl x:Class="BrowserApp.UI.Views.Workspaces.ChannelsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Loaded="ChannelsWorkspaceView_Loaded">

    <Grid Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:SymbolIcon Symbol="People24" FontSize="24" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Channels" Style="{StaticResource SectionTextStyle}"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="Browse and manage rule channels"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="Refresh" Margin="0,0,8,0"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Command="{Binding LoadChannelsCommand}"
                           Appearance="Secondary"/>
                <ui:Button Content="Sync Now" Margin="0,0,8,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding SyncNowCommand}"
                           Appearance="Primary"/>
                <ui:Button Content="New Channel"
                           Icon="{ui:SymbolIcon Add24}"
                           Command="{Binding CreateChannelCommand}"
                           Appearance="Secondary"/>
            </StackPanel>
        </Grid>

        <!-- Two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Joined Channels -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Joined Channels"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="8,8,8,8"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding JoinedChannels}"
                             SelectedItem="{Binding SelectedChannel}"
                             ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" Margin="4" CornerRadius="6"
                                        Background="{StaticResource BgGlassHeaderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{Binding ChannelName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Row="1" Text="{Binding ChannelDescription}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2" Text="{Binding LastSyncedDisplay}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                        <StackPanel Grid.Column="1" Grid.RowSpan="3"
                                                    VerticalAlignment="Center" Margin="8,0,0,0">
                                            <ui:Badge Appearance="Success">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Shield24" FontSize="12"/>
                                                    <TextBlock Text="{Binding RuleCount}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </ui:Badge>
                                            <ui:Button Content="Leave" Margin="0,8,0,0"
                                                       Appearance="Danger"
                                                       Command="{Binding DataContext.LeaveChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1" Text="No channels joined yet"
                               Visibility="{Binding JoinedChannels.Count, Converter={StaticResource CountToVisibility}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </Border>

            <!-- Available Channels -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Available Channels"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="8,8,8,8"/>

                    <ui:TextBox Grid.Row="1"
                                PlaceholderText="Search channels..."
                                Icon="{ui:SymbolIcon Search24}"
                                Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}"
                                Margin="4,0,4,8"/>

                    <ListBox Grid.Row="2" ItemsSource="{Binding AvailableChannels}"
                             ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" Margin="4" CornerRadius="6"
                                        Background="{StaticResource BgGlassHeaderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Description}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2" Text="{Binding DisplayInfo}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding OwnerUsername, StringFormat='by {0}'}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                        <ui:Button Grid.Column="1" Grid.RowSpan="4"
                                                   Content="Join"
                                                   VerticalAlignment="Center"
                                                   Appearance="Primary"
                                                   Command="{Binding DataContext.JoinChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="No channels available"
                               Visibility="{Binding AvailableChannels.Count, Converter={StaticResource CountToVisibility}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgElevatedBrush}" Padding="16,8" Margin="0,12,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                 HorizontalAlignment="Right"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
