<UserControl x:Class="BrowserApp.UI.Views.Workspaces.ProfilesWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Browser Profiles"
                           Style="{StaticResource TitleTextStyle}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="Each profile has its own bookmarks, history, and settings."
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <ui:Button Grid.Column="1" Content="+ New Profile"
                       Icon="{ui:SymbolIcon Add24}"
                       Command="{Binding CreateProfileCommand}"
                       Appearance="Primary"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Row 1: Active profile summary -->
        <Border Grid.Row="1"
                Background="{StaticResource BgGlassHeaderBrush}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                        Background="{Binding ActiveProfile.Color, Converter={StaticResource StringToBrush}}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="{Binding ActiveProfile.Name[0]}"
                               FontSize="16" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="Active: "/>
                        <Run Text="{Binding ActiveProfile.Name, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding ActiveProfileChannelSummary}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Profile list -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Profiles}"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource CardListItemStyle}"
                  BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="18"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{Binding Color, Converter={StaticResource StringToBrush}}">
                            <TextBlock Text="{Binding Name[0]}"
                                       FontSize="16" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                <Setter Property="Text" Value="Default profile"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Change color button -->
                        <ui:Button Grid.Column="2"
                                   Icon="{ui:SymbolIcon Color24}"
                                   Appearance="Secondary"
                                   ToolTip="Change color"
                                   Margin="4,0"
                                   VerticalAlignment="Center"
                                   Command="{Binding DataContext.ChangeProfileColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"/>

                        <!-- Switch button -->
                        <ui:Button Grid.Column="3"
                                   Content="Switch"
                                   Appearance="Primary"
                                   Margin="4,0"
                                   VerticalAlignment="Center"
                                   Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"/>

                        <!-- Delete button -->
                        <ui:Button Grid.Column="4"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Appearance="Secondary"
                                   VerticalAlignment="Center"
                                   ToolTip="Delete profile"
                                   Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityInverse}}"
                                   Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
