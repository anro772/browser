<UserControl x:Class="BrowserApp.UI.Views.Workspaces.RulesWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:BrowserApp.UI.Views"
             Loaded="RulesWorkspaceView_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <views:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Rules" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,4"/>
            <TextBlock Text="Site customizations, privacy headers, and content policies" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TotalRules}" FontWeight="SemiBold"/>
                <TextBlock Text=" rules total, " Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding EnabledRules}" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                <TextBlock Text=" enabled" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:DropDownButton Content="Load Template" Margin="0,0,8,0">
                    <ui:DropDownButton.Flyout>
                        <ContextMenu>
                            <MenuItem Header="Auto-Dismiss Cookie Banners" Command="{Binding LoadTemplateCommand}" CommandParameter="cookie-banners"/>
                            <MenuItem Header="Remove Sticky Headers" Command="{Binding LoadTemplateCommand}" CommandParameter="remove-sticky-headers"/>
                            <MenuItem Header="Force Dark Mode" Command="{Binding LoadTemplateCommand}" CommandParameter="force-dark-mode"/>
                            <Separator/>
                            <MenuItem Header="Privacy Headers" Command="{Binding LoadTemplateCommand}" CommandParameter="privacy-headers"/>
                            <MenuItem Header="Enterprise Content Policy" Command="{Binding LoadTemplateCommand}" CommandParameter="content-policy"/>
                        </ContextMenu>
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Command="{Binding LoadRulesCommand}"
                           Margin="0,0,8,0"/>
                <ui:Button Content="New Rule" Icon="{ui:SymbolIcon Add24}"
                           Command="{Binding CreateRuleCommand}"
                           Appearance="Primary"/>
            </StackPanel>
        </Grid>

        <!-- Search bar -->
        <ui:TextBox Grid.Row="2"
                    PlaceholderText="Search rules by name or site..."
                    Icon="{ui:SymbolIcon Search24}"
                    Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,0,0,8"/>

        <Grid Grid.Row="3">
            <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Rules}"
                          Style="{StaticResource ThemedDataGrid}"
                          SelectedItem="{Binding SelectedRule}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Enabled" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                     Command="{Binding DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                     CommandParameter="{Binding}"
                                                     IsEnabled="{Binding IsEnforced, Converter={StaticResource InverseBoolConverter}}"
                                                     HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Name" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" ToolTip="{Binding Description}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Site" Binding="{Binding Site}" Width="140"/>

                        <DataGridTemplateColumn Header="Actions" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                                                Background="#20F87171"
                                                Visibility="{Binding HasBlockActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding BlockActionCount}" FontSize="10" FontWeight="SemiBold" Foreground="#F87171"/>
                                                <TextBlock Text=" Block" FontSize="10" Foreground="#F87171"/>
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                                                Background="#20A78BFA"
                                                Visibility="{Binding HasCssActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding CssActionCount}" FontSize="10" FontWeight="SemiBold" Foreground="#A78BFA"/>
                                                <TextBlock Text=" CSS" FontSize="10" Foreground="#A78BFA"/>
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="4" Padding="5,2"
                                                Background="#20FBBF24"
                                                Visibility="{Binding HasJsActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding JsActionCount}" FontSize="10" FontWeight="SemiBold" Foreground="#FBBF24"/>
                                                <TextBlock Text=" JS" FontSize="10" Foreground="#FBBF24"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="60"/>

                        <DataGridTemplateColumn Header="Source" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" Margin="2"
                                            Background="{Binding SourceDisplay, Converter={StaticResource SourceTypeToColor}}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding SourceDisplay}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#0B0E12" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:Button ToolTip="Edit rule"
                                               Padding="4"
                                               Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Edit24" Foreground="{StaticResource AccentLightBrush}"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:Button Appearance="Danger"
                                               Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}"
                                               ToolTip="Delete rule"
                                               Padding="4">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="{StaticResource ErrorBrush}"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Background="{StaticResource BgPrimaryBrush}"
                    Opacity="0.82"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <ui:ProgressRing IsIndeterminate="True"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
