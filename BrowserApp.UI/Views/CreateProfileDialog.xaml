<ui:FluentWindow x:Class="BrowserApp.UI.Views.CreateProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Create Profile"
        Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        Style="{StaticResource ModernDialogWindowStyle}">

    <Grid Margin="20" Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding DialogTitle}" ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>

        <TextBlock Grid.Row="1" Text="{Binding DialogSubtitle}"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Profile name -->
        <ui:TextBox Grid.Row="2" x:Name="ProfileNameInput"
                    PlaceholderText="Profile name"
                    Margin="0,0,0,14"
                    Visibility="{Binding ShowNameField, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Color swatches -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="Profile color" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,8"/>
            <ItemsControl x:Name="ColorSwatches">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Padding="0" Margin="0,0,8,8"
                                Width="36" Height="36"
                                Click="ColorSwatch_Click"
                                Tag="{Binding}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SwatchBorder"
                                            Width="36" Height="36"
                                            CornerRadius="18"
                                            Background="{Binding Converter={StaticResource StringToBrush}}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="2"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SwatchBorder" Property="BorderBrush"
                                                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <ui:Button Content="Cancel"
                       IsCancel="True"
                       Click="CancelButton_Click"
                       Margin="0,0,8,0"/>
            <ui:Button x:Name="ConfirmButton" Content="Create"
                       Appearance="Primary"
                       IsDefault="True"
                       Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
