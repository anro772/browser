<ui:FluentWindow x:Class="BrowserApp.UI.Views.RuleEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:BrowserApp.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:RuleEditorViewModel}"
        Title="{Binding DialogTitle}"
        Height="700" Width="720"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        Style="{StaticResource ModernDialogWindowStyle}">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="20" Style="{StaticResource FadeInOnLoadModern}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="{Binding DialogTitle}" ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>

        <!-- Rule Metadata -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Rule Details" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding RuleName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="e.g. Block ads on example.com"
                                    Icon="{ui:SymbolIcon Edit24}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Site Pattern" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding SitePattern, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="*.example.com or * for all"
                                    Icon="{ui:SymbolIcon Globe24}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Description" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ui:TextBox Text="{Binding RuleDescription, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="What this rule does..."
                            Margin="0,0,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Priority" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:NumberBox Value="{Binding Priority}" Minimum="1" Maximum="100" Width="120"
                                      SpinButtonPlacementMode="Compact"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <ui:ToggleSwitch IsChecked="{Binding IsEnabled}" Content="Enabled"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Actions Header -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Actions" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Actions.Count, StringFormat=' ({0})'}"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <ui:Button Grid.Column="1"
                       Content="Add Action"
                       Icon="{ui:SymbolIcon Add24}"
                       Command="{Binding AddActionCommand}"
                       Appearance="Primary"
                       FontSize="12"/>
        </Grid>

        <!-- Actions List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding Actions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RuleActionEditorItem}">
                        <Border Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Action Header: Type selector + Remove -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Type" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Static vm:RuleActionEditorItem.ActionTypes}"
                                              SelectedItem="{Binding ActionType}"
                                              Width="180"
                                              HorizontalAlignment="Left"/>

                                    <ui:Button Grid.Column="2"
                                               ToolTip="Remove action"
                                               Appearance="Danger"
                                               Padding="4"
                                               Command="{Binding DataContext.RemoveActionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="{StaticResource ErrorBrush}"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </Grid>

                                <!-- Block Action Panel -->
                                <StackPanel Visibility="{Binding IsBlockType, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="URL Pattern" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding UrlPattern, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="*ads.example.com/* or *tracker*"
                                                Icon="{ui:SymbolIcon Link24}"
                                                Margin="0,0,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Resource Type" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{x:Static vm:RuleActionEditorItem.ResourceTypes}"
                                                      SelectedItem="{Binding ResourceType}"
                                                      IsEditable="False"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="HTTP Method" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{x:Static vm:RuleActionEditorItem.Methods}"
                                                      SelectedItem="{Binding Method}"
                                                      IsEditable="False"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- CSS Injection Panel -->
                                <StackPanel Visibility="{Binding IsCssType, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="URL Pattern (optional)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding UrlPattern, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Leave empty to apply to all pages on this site"
                                                Icon="{ui:SymbolIcon Link24}"
                                                Margin="0,0,0,8"/>

                                    <TextBlock Text="CSS to Inject" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding CssContent, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="100"
                                             MaxHeight="200"
                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                             FontSize="12"
                                             Background="{StaticResource BgElevatedBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}"
                                             Padding="8"/>
                                </StackPanel>

                                <!-- JS Injection Panel -->
                                <StackPanel Visibility="{Binding IsJsType, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="URL Pattern (optional)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding UrlPattern, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Leave empty to apply to all pages on this site"
                                                Icon="{ui:SymbolIcon Link24}"
                                                Margin="0,0,0,8"/>

                                    <TextBlock Text="JavaScript to Inject" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding JsContent, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="100"
                                             MaxHeight="200"
                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                             FontSize="12"
                                             Background="{StaticResource BgElevatedBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}"
                                             Padding="8"
                                             Margin="0,0,0,8"/>

                                    <StackPanel>
                                        <TextBlock Text="Timing" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{x:Static vm:RuleActionEditorItem.Timings}"
                                                  SelectedItem="{Binding Timing}"
                                                  Width="160"
                                                  HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Validation Error -->
        <TextBlock Grid.Row="4"
                   Text="{Binding ValidationError}"
                   Foreground="{StaticResource ErrorBrush}"
                   FontSize="12"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationError}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,0">
            <ui:Button Content="Cancel"
                       Command="{Binding CancelCommand}"
                       IsCancel="True"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Save Rule"
                       Appearance="Primary"
                       Command="{Binding SaveRuleCommand}"
                       IsDefault="True"
                       Icon="{ui:SymbolIcon Save24}"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
